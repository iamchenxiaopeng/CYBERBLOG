# ──────────────────────────────────────────────────────
# CyberBlog 环境变量模板（复制为 .env 并填入实际值）
# 复制命令：cp .env.example .env
# ──────────────────────────────────────────────────────

# MySQL
MYSQL_ROOT_PASSWORD=<请填入强密码>
MYSQL_DATABASE=cyberblog
MYSQL_USER=<请填入应用数据库用户名>
MYSQL_PASSWORD=<请填入强密码>

# Redis
REDIS_PASSWORD=<请填入强密码>

# MinIO
MINIO_ROOT_USER=<请填入MinIO用户名>
MINIO_ROOT_PASSWORD=<请填入强密码>
MINIO_BUCKET_NAME=cyberblog

# JWT（至少 256bit / 32 字符，建议用 openssl rand -base64 48 生成）
JWT_SECRET=<请填入随机密钥>

# 前端对外端口
FRONTEND_PORT=80
